{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Edit",
      "Bash(bun install --frozen-lockfile)",
      "Bash(bun run agent-browser * --help)",
      "Bash(bun run agent-browser * --version)",
      "Bash(bun run agent-browser --session vr-batch-* eval *)",
      "Bash(bun run agent-browser --session vr-batch-* get *)",
      "Bash(bun run agent-browser --session vr-batch-* open http://localhost*)",
      "Bash(bun run agent-browser --session vr-batch-* snapshot)",
      "Bash(bun run agent-browser --session vr-batch-* snapshot *)",
      "Bash(bun run agent-browser --session vr-batch-* screenshot)",
      "Bash(bun run agent-browser --session vr-batch-* screenshot *)",
      "Bash(bun run agent-browser --session vr-batch-* wait *)",
      "Bash(bun run agent-browser --session vr-batch-* close)",
      "Bash(bun run agent-browser --session vr-batch-* close *)",
      "Bash(bun run agent-browser --session vr-batch-* console)",
      "Bash(bun run agent-browser --session vr-batch-* console *)",
      "Bash(bun run agent-browser --session vr-batch-* errors)",
      "Bash(bun run agent-browser --session vr-batch-* errors *)",
      "Bash(bun run agent-browser --session vr-batch-* reload)",
      "Bash(bun run agent-browser close --all)",
      "Bash(cafleet doctor)",
      "Bash(cafleet --json doctor)",
      "Bash(cafleet --json session create *)",
      "Bash(cafleet --session-id * *)",
      "Bash(cafleet session delete *)",
      "Bash(cafleet session list)",
      "Bash(gh api repos/*/*/issues/*/comments)",
      "Bash(gh api repos/*/*/issues/*/comments *)",
      "Bash(gh api repos/*/*/issues/*/comments/* *)",
      "Bash(gh api repos/*/*/pulls/*/comments)",
      "Bash(gh api repos/*/*/pulls/*/comments *)",
      "Bash(gh api repos/*/*/pulls/*/comments/* *)",
      "Bash(gh api repos/*/*/pulls/*/reviews)",
      "Bash(gh api repos/*/*/pulls/*/reviews *)",
      "Bash(gh api repos/*/*/pulls/*/reviews/* *)",
      "Bash(gh api repos/*/*/pulls/*/requested_reviewers)",
      "Bash(gh auth status)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr edit * --add-reviewer @copilot)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh search *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git grep *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git branch *)",
      "Bash(git status)",
      "Bash(mise slidev *)",
      "Bash(mise run slidev *)",
      "Bash(sleep)",
      "Bash(sleep *)",
      "Bash(stat *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff check *)",
      "Bash(uv run ruff format *)",
      "Bash(uv run --frozen --project ~/.claude *.py)",
      "Bash(uv sync --frozen)",
      "Bash(uv sync --frozen *)",
      "NotebookEdit",
      "Read(/settings.json)",
      "Read(/skills/**)",
      "Read(/plugins/**)",
      "Read(//tmp/claude-code/**)",
      "Read(~/.agent-browser/tmp)",
      "Skill(cafleet)",
      "Skill(cafleet:agent-team-monitoring)",
      "Skill(create-figure)",
      "Skill(cafleet:design-doc)",
      "Skill(github-cli)",
      "Skill(cafleet:design-doc-create)",
      "Skill(cafleet:design-doc-execute)",
      "Skill(cafleet:design-doc-interview)",
      "Skill(research-presentation)",
      "Skill(pathfinder-explain)",
      "Skill(research-report)",
      "Skill(slidev:slidev)",
      "Skill(my-slidev)",
      "Skill(review-claude-config)",
      "Skill(nixos-boot-troubleshoot)",
      "WebFetch",
      "WebSearch",
      "Write",
      "Write(//tmp/claude-code/**)",
      "mcp__pathfinder-python__definition"
    ],
    "deny": [
      "Bash(awk *)",
      "Bash(bun install)",
      "Bash(bun run agent-browser open *)",
      "Bash(bun run agent-browser --session vr-batch-* set *)",
      "Bash(bun run agent-browser --session * wait --load networkidle)",
      "Bash(bun run agent-browser --session * wait --load networkidle *)",
      "Bash(bun run agent-browser wait --load networkidle)",
      "Bash(bun run agent-browser wait --load networkidle *)",
      "Bash(bun run agent-browser --session vr-batch-* eval)",
      "Bash(bun run agent-browser --session vr-batch-* eval *)",
      "Bash(bun run agent-browser eval)",
      "Bash(bun run agent-browser eval *)",
      "Bash(bun run agent-browser --session vr-batch-* wait)",
      "Bash(bun run agent-browser --session vr-batch-* wait *)",
      "Bash(bun run agent-browser wait)",
      "Bash(bun run agent-browser wait *)",
      "Bash(curl *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(git -C *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(kill *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(printf *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(tail *)",
      "Bash(touch *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(wget *)",
      "Bash(xargs *)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(uv sync)"
    ],
    "additionalDirectories": [
      "~/.claude"
    ]
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/validate_bash.py validate"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/english_review.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/bin/status.py"
  },
  "enabledPlugins": {
    "cafleet@cafleet": true,
    "agent-browser@himkt-marketplace": true,
    "slidev@himkt-marketplace": true
  },
  "extraKnownMarketplaces": {
    "cafleet": {
      "source": {
        "source": "github",
        "repo": "himkt/cafleet"
      }
    },
    "himkt-marketplace": {
      "source": {
        "source": "github",
        "repo": "himkt/himkt-marketplace"
      }
    }
  },
  "language": "Use professional English",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoMemoryEnabled": false,
  "autoCompactEnabled": false,
  "teammateMode": "in-process",
  "agentPushNotifEnabled": true,
  "autoInstallIdeExtension": false
}
