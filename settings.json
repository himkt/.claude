{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "high"
  },
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "additionalDirectories": [
      "~/.claude"
    ],
    "allow": [
      "Edit",
      "Bash(bun install)",
      "Bash(gh api repos/*/*/pulls/*/comments)",
      "Bash(gh api repos/*/*/pulls/*/comments *)",
      "Bash(gh api repos/*/*/pulls/*/reviews)",
      "Bash(gh api repos/*/*/pulls/*/reviews *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh search *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git branch *)",
      "Bash(git status)",
      "Bash(script -q /dev/null bun run slidev --open false */slide.md)",
      "Bash(script -qfc 'bun run slidev --open false */slide.md' /dev/null)",
      "Bash(tmux ls *)",
      "Bash(uv sync *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff check *)",
      "Bash(uv run --project ~/.claude *)",
      "Bash(uv run ruff format *)",
      "NotebookEdit",
      "Read(/settings.json)",
      "Read(/skills/**)",
      "Read(/plugins/**)",
      "Read(//tmp/claude-code/**)",
      "Skill(create-figure)",
      "Skill(design-doc)",
      "Skill(github-cli)",
      "Skill(design-doc-create)",
      "Skill(design-doc-execute)",
      "Skill(design-doc-interview)",
      "Skill(research-presentation)",
      "Skill(pathfinder-explain)",
      "Skill(sync-skills)",
      "Skill(research-report)",
      "Skill(slidev)",
      "Skill(my-slidev)",
      "Skill(review-claude-config)",
      "Skill(nixos-boot-troubleshoot)",
      "WebFetch",
      "WebSearch",
      "Write",
      "Write(//tmp/claude-code/**)",
      "mcp__pathfinder-python__definition",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_wait_for"
    ],
    "deny": [
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(printf *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(tail *)",
      "Bash(touch *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(git -C *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(python *)",
      "Bash(python3 *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowRead": [
        "~/.claude",
        "~/.cache",
        "~/.bun",
        "~/.config",
        "~/.gitconfig"
      ],
      "allowWrite": [
        "~/.cache/uv",
        "~/.claude/.venv",
        "~/.bun"
      ]
    }
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/validate_bash.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/bin/status.py"
  },
  "enabledPlugins": {
    "external-skills@himkt-marketplace": true
  },
  "extraKnownMarketplaces": {
    "himkt-marketplace": {
      "source": {
        "source": "github",
        "repo": "himkt/himkt-marketplace"
      }
    }
  },
  "language": "Use Japanese for chat conversations, English for writing files",
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": false,
  "teammateMode": "tmux",
  "autoInstallIdeExtension": false
}
