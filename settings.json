{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Edit",
      "Bash(bun install --frozen-lockfile)",
      "Bash(bun run agent-browser * --help)",
      "Bash(bun run agent-browser * --version)",
      "Bash(bun run agent-browser --session vr-batch-* open http://localhost:3030*)",
      "Bash(bun run agent-browser --session vr-batch-* snapshot)",
      "Bash(bun run agent-browser --session vr-batch-* snapshot *)",
      "Bash(bun run agent-browser --session vr-batch-* screenshot)",
      "Bash(bun run agent-browser --session vr-batch-* screenshot *)",
      "Bash(bun run agent-browser --session vr-batch-* wait *)",
      "Bash(bun run agent-browser --session vr-batch-* close)",
      "Bash(bun run agent-browser --session vr-batch-* close *)",
      "Bash(bun run agent-browser --session vr-batch-* console)",
      "Bash(bun run agent-browser --session vr-batch-* console *)",
      "Bash(bun run agent-browser --session vr-batch-* errors)",
      "Bash(bun run agent-browser --session vr-batch-* errors *)",
      "Bash(bun run agent-browser --session vr-batch-* reload)",
      "Bash(bun run agent-browser close --all)",
      "Bash(cafleet *)",
      "Bash(gh api repos/*/*/pulls/*/comments)",
      "Bash(gh api repos/*/*/pulls/*/comments *)",
      "Bash(gh api repos/*/*/pulls/*/reviews)",
      "Bash(gh api repos/*/*/pulls/*/reviews *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr edit * --add-reviewer @copilot)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh search *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git branch *)",
      "Bash(git status)",
      "Bash(script -q /dev/null bun run slidev --open false */slide.md)",
      "Bash(script -qfc 'bun run slidev --open false */slide.md' /dev/null)",
      "Bash(script -qfc \"bun run slidev --open false */slide.md\" /dev/null)",
      "Bash(tmux ls)",
      "Bash(tmux ls *)",
      "Bash(tmux list-panes)",
      "Bash(tmux list-panes *)",
      "Bash(tmux capture-pane *)",
      "Bash(tmux display-message *)",
      "Bash(stat *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff check *)",
      "Bash(uv run ruff format *)",
      "Bash(uv run --frozen --project ~/.claude *.py)",
      "Bash(uv sync --frozen *)",
      "NotebookEdit",
      "Read(/settings.json)",
      "Read(/skills/**)",
      "Read(/plugins/**)",
      "Read(//tmp/claude-code/**)",
      "Read(~/.agent-browser/tmp)",
      "Skill(cafleet)",
      "Skill(cafleet-monitoring)",
      "Skill(create-figure)",
      "Skill(design-doc)",
      "Skill(github-cli)",
      "Skill(design-doc-create)",
      "Skill(design-doc-execute)",
      "Skill(design-doc-interview)",
      "Skill(research-presentation)",
      "Skill(pathfinder-explain)",
      "Skill(research-report)",
      "Skill(slidev)",
      "Skill(my-slidev)",
      "Skill(review-claude-config)",
      "Skill(nixos-boot-troubleshoot)",
      "WebFetch",
      "WebSearch",
      "Write",
      "Write(//tmp/claude-code/**)",
      "mcp__pathfinder-python__definition"
    ],
    "deny": [
      "Bash(awk *)",
      "Bash(bun install)",
      "Bash(bun run agent-browser open *)",
      "Bash(bun run agent-browser --session vr-batch-* set *)",
      "Bash(cat *)",
      "Bash(curl *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(printf *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(tail *)",
      "Bash(touch *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(git -C *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(wc *)",
      "Bash(wget *)",
      "Bash(kill *)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(uv sync)",
      "Bash(cafleet --session-id * member send-input *)"
    ],
    "additionalDirectories": [
      "~/.claude"
    ]
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/validate_bash.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/english_review.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/bin/status.py"
  },
  "enabledPlugins": {
    "external-skills@himkt-marketplace": true
  },
  "extraKnownMarketplaces": {
    "himkt-marketplace": {
      "source": {
        "source": "github",
        "repo": "himkt/himkt-marketplace"
      }
    }
  },
  "language": "Use professional English",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoMemoryEnabled": false,
  "teammateMode": "tmux",
  "autoInstallIdeExtension": false
}
